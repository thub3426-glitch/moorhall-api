# Server Configuration
PORT=3005
NODE_ENV=production
BACKEND_URL=https://your-site.netlify.app
FRONTEND_URL=https://your-frontend-domain.com

# Database (Required - PostgreSQL with Prisma ORM)
# Recommended cloud providers: Supabase, Railway, AWS RDS
# Connection string must include ?sslmode=require for Netlify
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# JWT Secrets (Generate secure random strings - minimum 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secure-jwt-secret-key-minimum-32-characters"
SESSION_SECRET="your-session-secret-key-minimum-32-characters"

# CORS Configuration for Netlify
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Google OAuth (Optional - for admin authentication)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (SendGrid Recommended for Production)
#
# IMPORTANT: For Netlify deployment, use a transactional email service.
# Recommended: SendGrid, Mailgun, Postmark, or similar.
# See docs/NETLIFY_DEPLOYMENT.md and docs/EMAIL_SETUP.md for detailed setup.
#
# Transactional providers offer better deliverability, retries, and analytics.
# Configure the primary provider via `EMAIL_PROVIDER` or use the custom SMTP vars below.
# Examples:
# EMAIL_PROVIDER=custom
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-username
# SMTP_PASS=your-password

# Fallback Email Provider (optional)
# For development, use Mailtrap: https://mailtrap.io
# EMAIL_FALLBACK_PROVIDER=mailtrap
# MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
# MAILTRAP_SMTP_PORT=2525
# MAILTRAP_SMTP_USER=your-mailtrap-username
# MAILTRAP_SMTP_PASS=your-mailtrap-password

# Custom SMTP (alternative to Mailtrap)
# SMTP_HOST=smtp.custom.com
# SMTP_PORT=587
# SMTP_USER=your-username
# SMTP_PASS=your-password
# SMTP_SECURE=false

# Email Identity
EMAIL_FROM_NAME=Moor Hall
EMAIL_FROM_ADDRESS=noreply@moorhall.com
EMAIL_REPLY_TO=support@moorhall.com

# Admin notification emails (comma-separated)
ADMIN_EMAILS=admin@moorhall.com

# Auto-reply message for contact form
AUTO_REPLY_MESSAGE=Thank you for contacting Moor Hall. Our team will review your message and get back to you within 1-2 business days.

# Frontend URL (used for email links, CORS, and redirects)
FRONTEND_URL=https://your-frontend-domain.com

# Cloudinary (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio (Optional - for SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER="+1234567890"

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pindo (Optional - for SMS in certain regions)
PINDO_ACCESS_TOKEN=your-pindo-token
PINDO_SENDER_ID=YourSenderID

# Firebase (Optional - for push notifications)
FIREBASE_SERVICE_JSON_PATH=path-to-firebase-service-account.json

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-...

# Google Maps (Optional - for location services)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SERVER_MAPS_API_KEY=your-server-maps-api-key

# Internal Service Token
INTERNAL_SERVICE_TOKEN=your-internal-secure-token

# WhatsApp Cloud API (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_DEFAULT_COUNTRY_CODE=250

# Cookie Configuration (for production)
COOKIE_DOMAIN=your-domain.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
