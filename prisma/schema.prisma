generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                  Int          @id @default(autoincrement())
  fullName            String
  email               String       @unique
  phoneNumber         String?      @unique
  passwordHash        String
  role                AdminRole    @default(ADMIN)
  status              AdminStatus  @default(ACTIVE)
  lastLoginAt         DateTime?
  passwordResetToken  String?
  passwordResetExpires DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  ordersReviewed       Order[]              @relation("OrderReviewedBy")
  ordersConfirmed      Order[]              @relation("OrderConfirmedBy")
  ordersApproved       Order[]              @relation("OrderApprovedBy")
  paymentsVerified     Payment[]
  reservationsReviewed Reservation[]
  cateringReviewed     CateringRequest[]
  statusHistoryChanges OrderStatusHistory[]
  notificationsSent    NotificationLog[]
  contentUpdated       ContentSection[]
  settingsUpdated      SiteSetting[]
  auditLogs            AuditLog[]
  activityLogs         ActivityLog[]
}

model MenuCategory {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  slug         String       @unique
  description  String?
  type         CategoryType
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  items MenuItem[]
}

model MenuItem {
  id               Int         @id @default(autoincrement())
  categoryId       Int
  name             String
  slug             String      @unique
  shortDescription String?
  description      String?
  productType      ProductType
  price            Decimal     @db.Decimal(10, 2)
  imageUrl         String?
  imagePublicId    String?     // Cloudinary public ID for deletion/management
  images           Json?       // Array of additional image URLs
  isAvailable      Boolean     @default(true)
  isFeatured       Boolean     @default(false)
  preparationTime  Int?
  sku              String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([productType])
  @@index([isAvailable])
}

model ServiceItem {
  id             Int         @id @default(autoincrement())
  name           String
  slug           String      @unique
  type           ServiceType
  description    String?
  imageUrl       String?
  imagePublicId  String?     // Cloudinary public ID for deletion/management
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Order {
  id                       Int                @id @default(autoincrement())
  orderNumber              String             @unique
  customerName             String
  customerPhone            String
  customerAltPhone         String?
  deliveryAddress          String?
  locationNotes            String?
  orderType                OrderType
  sourceChannel            OrderSource        @default(WEBSITE)
  notes                    String?
  subtotal                 Decimal            @db.Decimal(10, 2)
  deliveryFee              Decimal            @default(0) @db.Decimal(10, 2)
  discountAmount           Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount              Decimal            @db.Decimal(10, 2)
  paymentMethod            PaymentMethod      @default(MOMO_MANUAL)
  paymentArrangement       PaymentArrangement
  paymentRuleSnapshot      Json?
  paymentStatus            PaymentStatus      @default(WAITING_PAYMENT)
  paymentMode              PaymentMode        @default(FULL_PAYMENT_BEFORE_APPROVAL)
  requiredPaymentAmount    Decimal            @db.Decimal(10, 2)
  paidAmount               Decimal            @default(0) @db.Decimal(10, 2)
  remainingAmount          Decimal            @db.Decimal(10, 2)
  status                   OrderStatus        @default(PENDING)
  customerPaymentReference String?
  customerPaymentProofNote String?
  paymentSlipReference     String?
  reviewedByAdminId        Int?
  confirmedByAdminId       Int?
  confirmedAt              DateTime?
  approvedByAdminId        Int?
  approvedAt              DateTime?
  cancelledAt              DateTime?
  cancellationReason       String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  reviewedBy    Admin?               @relation("OrderReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  confirmedBy   Admin?               @relation("OrderConfirmedBy", fields: [confirmedByAdminId], references: [id], onDelete: SetNull)
  approvedBy    Admin?               @relation("OrderApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      Payment[]
  history       OrderStatusHistory[]
  notifications NotificationLog[]
  receipt       Receipt?

  @@index([customerPhone])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id                      Int       @id @default(autoincrement())
  orderId                 Int
  menuItemId              Int?
  itemNameSnapshot        String
  itemDescriptionSnapshot String?
  unitPriceSnapshot       Decimal   @db.Decimal(10, 2)
  quantity                Int
  lineTotal               Decimal   @db.Decimal(10, 2)
  specialInstructions     String?
  createdAt               DateTime  @default(now())

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([menuItemId])
}

model Payment {
  id                 Int                @id @default(autoincrement())
  orderId            Int
  method             PaymentMethod
  arrangement        PaymentArrangement
  expectedAmount     Decimal            @db.Decimal(10, 2)
  amountPaid         Decimal            @default(0) @db.Decimal(10, 2)
  outstandingBalance Decimal            @default(0) @db.Decimal(10, 2)
  status             PaymentStatus      @default(WAITING_PAYMENT)
  payerPhone         String?
  transactionRef     String?
  proofAttachmentUrl String?
  notes              String?
  verifiedByAdminId  Int?
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifiedBy    Admin?            @relation(fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  notifications NotificationLog[]

  @@index([orderId])
  @@index([status])
}

model PaymentRule {
  id                         Int                @id @default(autoincrement())
  name                       String             @unique
  appliesToOrderType         OrderType?
  appliesToCategoryType      CategoryType?
  minimumAmount              Decimal?           @db.Decimal(10, 2)
  partialPercent             Decimal?           @db.Decimal(5, 2)
  requiresFullBeforeDelivery Boolean            @default(false)
  allowsPayOnDelivery        Boolean            @default(false)
  isActive                   Boolean            @default(true)
  priority                   Int                @default(0)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
}

model Reservation {
  id                Int               @id @default(autoincrement())
  customerName      String
  phoneNumber       String
  reservationDate   DateTime
  reservationTime   String
  guestCount        Int
  notes             String?
  status            ReservationStatus @default(PENDING)
  reviewedByAdminId Int?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  reviewedBy    Admin?            @relation(fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  notifications NotificationLog[]

  @@index([phoneNumber])
  @@index([status])
}

model CateringRequest {
  id                Int            @id @default(autoincrement())
  customerName      String
  phoneNumber       String
  email             String?
  eventType         String
  eventLocation     String
  guestCount        Int
  preferredDate     DateTime
  budgetRange       String?
  notes             String?
  images            Json?          // Array of {secure_url, public_id} for catering event images
  status            CateringStatus @default(PENDING)
  reviewedByAdminId Int?
  reviewedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  reviewedBy    Admin?            @relation(fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  notifications NotificationLog[]

  @@index([phoneNumber])
  @@index([status])
}

model NotificationLog {
  id                Int                 @id @default(autoincrement())
  orderId           Int?
  paymentId         Int?
  reservationId     Int?
  cateringRequestId Int?
  sentByAdminId     Int?
  phoneNumber       String
  channel           NotificationChannel @default(WHATSAPP)
  type              NotificationType
  messageSummary    String
  providerName      String?
  providerReference String?
  providerMessageId String?
  sentStatus        SendStatus          @default(PENDING)
  failureReason     String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  createdAt         DateTime            @default(now())

  order           Order?           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment         Payment?         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  reservation     Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  cateringRequest CateringRequest? @relation(fields: [cateringRequestId], references: [id], onDelete: Cascade)
  sentByAdmin     Admin?           @relation(fields: [sentByAdminId], references: [id], onDelete: SetNull)
  webhookEvents   WhatsAppWebhookEvent[]
  receipt         Receipt?         @relation("NotificationLogToReceipt")

  @@index([phoneNumber])
  @@index([type])
  @@index([sentStatus])
}

model OrderStatusHistory {
  id                Int         @id @default(autoincrement())
  orderId           Int
  previousStatus    OrderStatus?
  newStatus         OrderStatus
  changedByAdminId  Int?
  note              String?
  notificationSent  Boolean     @default(false)
  notificationLogId Int?
  createdAt         DateTime    @default(now())

  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy Admin? @relation(fields: [changedByAdminId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model ContentSection {
  id               Int      @id @default(autoincrement())
  key              String   @unique
  title            String?
  body             String?
  dataJson         Json?
  isPublished      Boolean  @default(true)
  updatedByAdminId Int?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  updatedBy Admin? @relation(fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model Promotion {
  id                   Int      @id @default(autoincrement())
  title                String
  description          String?
  imageUrl             String?
  imagePublicId        String?  // Cloudinary public ID for deletion/management
  discountPercentage   Int?     // Discount percentage (e.g., 45 for 45%)
  originalPrice        Decimal? @db.Decimal(10, 2)
  discountedPrice      Decimal? @db.Decimal(10, 2)
  startDate            DateTime?
  endDate              DateTime?
  isActive             Boolean  @default(true)
  displayOrder         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model GalleryItem {
  id           Int         @id @default(autoincrement())
  title        String?
  imageUrl     String
  imagePublicId String?    // Cloudinary public ID for deletion/management
  imageType    GalleryType
  displayOrder Int         @default(0)
  isPublished  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SiteSetting {
  id               Int      @id @default(autoincrement())
  key              String   @unique
  value            String
  updatedByAdminId Int?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  updatedBy Admin? @relation(fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model ContactMessage {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  subject     String?
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int?
  action     String
  entityType String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

enum AdminRole {
  ADMIN
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

enum CategoryType {
  FOOD
  COFFEE
  DRINK
  BAKERY
  SPECIAL
}

enum ProductType {
  FOOD
  COFFEE
  DRINK
  BAKERY
}

enum ServiceType {
  DELIVERY
  OUTSIDE_CATERING
  BAKERY_SERVICE
  COFFEE_SHOP_SERVICE
  CUSTOMER_CONVENIENCE
  BUSINESS_PUBLICITY
  EVENT_SERVICE
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN_REQUEST
}

enum OrderSource {
  WEBSITE
  WHATSAPP
  PHONE_CALL
  WALK_IN
  ADMIN
}

enum OrderStatus {
  PENDING
  PAYMENT_WAITING
  PAYMENT_UNDER_REVIEW
  APPROVED
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  MOMO_MANUAL
  CASH
  BANK_TRANSFER
  OTHER
}

enum PaymentArrangement {
  FULL_BEFORE_DELIVERY
  PARTIAL_BEFORE_DELIVERY
  PAY_ON_DELIVERY
  CUSTOM
  CATERING_CUSTOM
}

enum PaymentStatus {
  NOT_REQUIRED
  WAITING_PAYMENT
  UNDER_REVIEW
  PARTIALLY_PAID
  PAID
  REJECTED
  FAILED
  CANCELLED
}

enum PaymentMode {
  FULL_PAYMENT_BEFORE_APPROVAL
  HALF_PAYMENT_BEFORE_APPROVAL
  PAY_ON_DELIVERY
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum CateringStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS
  IN_APP
}

enum NotificationType {
  ORDER_PLACED
  PAYMENT_INSTRUCTION
  PAYMENT_CONFIRMED
  PARTIAL_PAYMENT_ACKNOWLEDGED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY
  ORDER_OUT_FOR_DELIVERY
  ORDER_COMPLETED
  ORDER_CANCELLED
  RECEIPT_SENT
  RESERVATION_UPDATE
  CATERING_UPDATE
  CUSTOM_MESSAGE
}

enum SendStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
  READ
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  type        ActivityType
  entityType  String
  entityId    Int?
  message     String
  status      String?
  metadata    Json?
  adminId     Int?
  createdAt   DateTime  @default(now())

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model WhatsAppWebhookEvent {
  id              Int       @id @default(autoincrement())
  providerEventId String?
  messageType     String?
  from            String
  to              String?
  messageId       String?
  status          String?
  errorCode       String?
  errorMessage    String?
  rawPayload      Json?
  notificationLogId Int?
  createdAt       DateTime  @default(now())

  notificationLog NotificationLog? @relation(fields: [notificationLogId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([from])
  @@index([createdAt])
}

enum ActivityType {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_STATUS_CHANGED
  WHATSAPP_SEND_ATTEMPT
  WHATSAPP_SENT
  WHATSAPP_FAILED
  RECEIPT_GENERATED
  RECEIPT_SENT
  ADMIN_ACTION
}

enum GalleryType {
  FOOD
  COFFEE
  BAKERY
  DRINK
  RESTAURANT
  EVENT
  CATERING
}

model Receipt {
  id              Int       @id @default(autoincrement())
  orderId         Int       @unique
  receiptNumber   String    @unique
  receiptUrl      String?
  generatedAt     DateTime  @default(now())
  sentAt          DateTime?
  notificationLogId Int?    @unique

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  notificationLog NotificationLog? @relation("NotificationLogToReceipt", fields: [notificationLogId], references: [id], onDelete: SetNull)

  @@index([receiptNumber])
  @@index([generatedAt])
}